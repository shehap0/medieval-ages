---
export interface Props {
  size?: number;
  class?: string;
}
const { size = 28, class: cls = '' } = Astro.props;
---
<svg
  class={`brand__mark ${cls}`}
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  aria-hidden="true"
  focusable="false"
>
  <!-- Heraldic shield: a quarterly shield with a horizontal bar and four
       small charges (a deliberate, named mark, not a random sigil). -->
  <path
    d="M16 1.5 L28 4.5 V14.5 C28 22 22.5 27 16 30.5 C9.5 27 4 22 4 14.5 V4.5 Z"
    stroke="currentColor"
    stroke-width="1.4"
    fill="none"
  />
  <line x1="4" y1="13" x2="28" y2="13" stroke="currentColor" stroke-width="1.4" />
  <line x1="16" y1="1.5" x2="16" y2="30.5" stroke="currentColor" stroke-width="1.4" />
  <circle cx="10" cy="8" r="1.3" fill="currentColor" />
  <circle cx="22" cy="8" r="1.3" fill="currentColor" />
  <circle cx="10" cy="20" r="1.3" fill="currentColor" />
  <circle cx="22" cy="20" r="1.3" fill="currentColor" />
</svg>
